#!/usr/bin/env bash

main() {
    if [ $# != 1 ]; then
        echo "Usage: $0 <git_global_config_user.signingkey>"
        return 1
    fi

    signingkey=$1

    read -r name email <<< "$(gpg --list-key "$signingkey" | sed -n 's/uid           \[ultimate\] //; 3s/[<>]//g; 3p')"

    /usr/bin/ruby -e "$(curl -fsSL https://raw.githubusercontent.com/Homebrew/install/master/install)"

    brew install \
        autojump \
        asciinema \
        bash-completion \
        bat \
        fpp \
        fzf \
        git \
        git-crypt \
        gpg \
        jq \
        ncdu \
        noti \
        python-yq \
        ripgrep \
        surfraw \
        tig \
        tldr \
        todo-txt \
        vim \
        w3m \
        watchman \
        yarn

    brew cask install \
        android-file-transfer \
        clipy \
        firefox \
        gimp \
        google-chrome \
        homebrew/cask-versions/firefox-developer-edition \
        insomnia \
        karabiner-elements \
        keepassxc \
        keybase \
        libreoffice \
        licecap \
        opera \
        origin \
        postman \
        skype \
        slimbatterymonitor \
        spectacle \
        squirrel \
        steam \
        syncthing-app \
        tor-browser \
        vagrant \
        virtualbox \
        virtualbox-extension-pack

    yarn global add \
        typescript # for YouCompleteMe

    curl https://sh.rustup.rs -sSf | sh

    git clone --depth=1 https://github.com/Bash-it/bash-it.git ~/.bash_it &&
        ~/.bash_it/install.sh

    bash-it enable alias \
        docker \
        docker-compose \
        general \
        git \
        homebrew \
        homebrew-cask \
        npm \
        osx \
        todo.txt-cli \
        vagrant \
        yarn

    bash-it enable completion \
        brew \
        docker \
        docker-compose \
        docker-machine \
        git \
        makefile \
        npm \
        ssh \
        system \
        todo \
        vagrant

    bash-it enable plugin \
        autojump \
        extract \
        git \
        todo

    find . -type f \
        -depth 1 \
        -name '.*' \
        ! -name .gitconfig \
        ! -name .gitmodules |
        sort |
        sed "s@^.@$PWD@" |
        xargs -I {} ln -s {} ~

    cp .gitconfig ~

    mkdir -p ~/.cache/vim-gutentags

    vim -S ~/.vim/snapshot.vim

    git config --global user.email "$email"
    git config --global user.name "$name"
    git config --global user.signingkey "$signingkey"
}

main "$*"

echo 'REMEMBER:'
echo '- Automatically rearrange Spaces based on most recent use'
echo '- Dashboard: As Overlay'
