#!/usr/bin/env bash

main() {
    if [ $# != 1 ]; then
        echo "Usage: $0 <git_global_config_user.signingkey>"
        return 1
    fi

    signingkey=$1

    IFS='<' read -r name email <<< "$(gpg --list-key "$signingkey" | sed -n 's/uid           \[ultimate\] //; 3s/>//g; 3s/ </</; 3p')"

    /usr/bin/ruby -e "$(curl -fsSL https://raw.githubusercontent.com/Homebrew/install/master/install)"

    brew install \
        autojump \
        asciinema \
        bash-completion \
        bat \
        ctags \
        direnv \
        elixir \
        erlang \
        exercism \
        fd \
        fpp \
        fzf \
        git \
        git-crypt \
        gitup \
        gpg \
        hr \
        httpie \
        hub \
        jq \
        lua \
        ncdu \
        nnn \
        node@10 \
        noti \
        octave \
        postgresql \
        python-yq \
        ripgrep \
        shellcheck \
        shfmt \
        surfraw \
        tig \
        tldr \
        todo-txt \
        vim \
        w3m \
        watchman \
        yarn

    brew cask install \
        chromedriver \
        clipy \
        devdocs \
        firefox \
        firefox-developer-edition \
        gimp \
        google-chrome \
        insomnia \
        karabiner-elements \
        keepassxc \
        keybase \
        opera \
        operadriver \
        postman \
        quicklook-json \
        remember-the-milk \
        slack \
        spectacle \
        squirrel \
        toggl \
        vagrant \
        virtualbox \
        virtualbox-extension-pack

    brew cask install \
        adobe-acrobat-reader \
        android-file-transfer \
        anki \
        libreoffice \
        notion \
        origin \
        polar-bookshelf \
        rescuetime \
        skype \
        steam \
        syncthing-app \
        tor-browser

    npm --global install \
        typescript # for YouCompleteMe

    curl https://sh.rustup.rs -sSf | sh

    git clone --depth=1 https://github.com/Bash-it/bash-it.git ~/.bash_it &&
        ~/.bash_it/install.sh

    bash-it enable alias \
        docker \
        docker-compose \
        general \
        git \
        homebrew \
        homebrew-cask \
        npm \
        osx \
        todo.txt-cli \
        vagrant \
        yarn

    bash-it enable completion \
        brew \
        docker \
        docker-compose \
        docker-machine \
        git \
        makefile \
        npm \
        ssh \
        system \
        todo \
        vagrant

    bash-it enable plugin \
        autojump \
        direnv \
        extract \
        fzf \
        git \
        todo

    find . \
        -depth 1 \
        -name '.*' \
        ! -name .git \
        ! -name .gitconfig \
        ! -name .gitmodules |
        sort |
        sed "s@^.@$PWD@" |
        xargs -I {} ln -s {} ~

    cp .gitconfig ~

    mkdir -p ~/.cache/vim-gutentags

    vim -S ~/.vim/snapshot.vim

    git config --global user.email "$email"
    git config --global user.name "$name"
    git config --global user.signingkey "$signingkey"
    git config --global --list
}

main "$*"

echo 'REMEMBER:'
echo '- Automatically rearrange Spaces based on most recent use'
echo '- Dashboard: As Overlay'
