#!/usr/bin/env bash

# GIPHY Capture. The GIF Maker on the Mac App Store https://itunes.apple.com/app/id668208984
# Thor on the Mac App Store https://itunes.apple.com/app/thor/id1120999687

main() {
    if [ $# != 1 ]; then
        echo "Usage: $0 <git_global_config_user.signingkey>"
        return 1
    fi

    signingkey=$1

    IFS='<' read -r name email <<< "$(gpg --list-key "$signingkey" | sed -n 's/uid           \[ultimate\] //; 3s/>//g; 3s/ </</; 3p')"

    /usr/bin/ruby -e "$(curl -fsSL https://raw.githubusercontent.com/Homebrew/install/master/install)"

    brew install \
        autojump \
        cask-repair \
        ctags \
        direnv \
        elixir \
        erlang \
        fd \
        fzf \
        git \
        git-crypt \
        gitlab-gem \
        gnupg \
        hr \
        hub \
        jq \
        mas \
        ncdu \
        node \
        node@10 \
        noti \
        ripgrep \
        rmtrash \
        screen \
        shellcheck \
        shfmt \
        tig \
        tldr \
        typescript \
        vim \
        watchman \
        zbar

    # brew install \
    #     asciinema \
    #     bat \
    #     exercism \
    #     fpp \
    #     gitup \
    #     nnn \
    #     octave \
    #     phantomjs \
    #     python-yq \
    #     surfraw \
    #     todo-txt \
    #     w3m

    brew cask install \
        chromedriver \
        chromium \
        clipy \
        drawio \
        firefox \
        firefox-developer-edition \
        gimp \
        insomnia \
        karabiner-elements \
        keepassxc \
        keybase \
        mongodb-compass-community \
        postman \
        quicklook-json \
        remember-the-milk \
        slack \
        spectacle \
        squirrel \
        vagrant \
        virtualbox \
        virtualbox-extension-pack \
        zoomus

    brew cask install \
        adobe-acrobat-reader \
        anki \
        brave-browser \
        google-chrome \
        libreoffice \
        notion \
        opera \
        operadriver \
        origin \
        polar-bookshelf \
        rescuetime \
        skype \
        steam \
        syncthing-app \
        toggl \
        tor-browser \
        vivaldi

    # brew cask install \
    #     android-file-transfer \
    #     devdocs \
    #     squirrel \

    curl https://sh.rustup.rs -sSf | sh

    git clone --depth=1 https://github.com/Bash-it/bash-it.git ~/.bash_it &&
        ~/.bash_it/install.sh

    bash-it enable alias \
        docker \
        docker-compose \
        general \
        git \
        homebrew \
        homebrew-cask \
        npm \
        osx \
        todo.txt-cli \
        vagrant \
        yarn

    bash-it enable completion \
        brew \
        docker \
        docker-compose \
        docker-machine \
        git \
        makefile \
        npm \
        ssh \
        system \
        todo \
        vagrant

    bash-it enable plugin \
        autojump \
        direnv \
        extract \
        fzf \
        git \
        todo

    find . \
        -depth 1 \
        -name '.*' \
        ! -name .git \
        ! -name .gitconfig \
        ! -name .gitmodules |
        sort |
        sed "s@^.@$PWD@" |
        xargs -I {} ln -fs {} ~

    cp .gitconfig ~

    mkdir -p ~/.cache/vim-gutentags

    vim -S ~/.vim/snapshot.vim

    git config --global user.email "$email"
    git config --global user.name "$name"
    git config --global user.signingkey "$signingkey"
    git config --global --list
}

main "$*"

echo 'REMEMBER:'
echo '- Automatically rearrange Spaces based on most recent use'
echo '- Dashboard: As Overlay'
