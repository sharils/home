global !p
from my_snippet_helpers import *
endglobal


priority 3

snippet taa "afterAll" b
afterAll(function() {
	${1:${VISUAL}}
});
endsnippet

snippet tae "afterEach" b
afterEach(function() {
	${1:${VISUAL}}
});
endsnippet

snippet taf "after" b
after(function() {
	${1:${VISUAL}}
});
endsnippet

snippet tba "beforeAll" b
beforeAll(function() {
	${1:${VISUAL}}
});
endsnippet

snippet tbe "beforeEach" b
beforeEach(function() {
	${1:${VISUAL}}
});
endsnippet

snippet tbf "before" b
before(function() {
	${1:${VISUAL}}
});
endsnippet

snippet expect "expect" b
expect($1)
endsnippet

snippet tde "describe" b
describe("$1", function() {
	${2:${VISUAL}}
});
endsnippet

snippet tex "expect" b
expect
endsnippet

snippet tit "it" b
it("$1", $2function() {
	${3:${VISUAL}}
})
endsnippet
