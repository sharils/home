snippet <> "<element attr></element>" w
<$1>$2</`!p snip.rv = re.sub(' .*', '', t[1])`>
endsnippet

snippet tag "<element attr></element>" w
<$1>
	$2${VISUAL}
</`!p snip.rv = re.sub(' .*', '', t[1])`>
endsnippet

snippet a "a" w
<a href="$1">
	${2:$1}
</a>
endsnippet

snippet ai "a>img" w
<a href="${3:$2}">
	<img alt="$1" src="${2}">
</a>
endsnippet

snippet div "div" w
<div>$1</div>
endsnippet

snippet h "html" "len(snip.buffer) == 1" e
<!DOCTYPE html>
<html lang="en">
<head>
	<meta charset="utf-8">
	<title>$1</title>
</head>
<body>
	$2
</body>
</html>
endsnippet

snippet l "link" b
<link rel="stylesheet" type="text/css" href="${1:index}.css" />
endsnippet

snippet ss "script" w
<script src="$1"></script>
endsnippet

snippet st "style" w
<style type="text/css">$1
</style>
endsnippet
