global !p
from my_snippet_helpers import *
endglobal


priority 4

snippet d "default" "around_require(snip)" ie
default
endsnippet

snippet r "require" "around_assign_or_line_start(snip)" we
require("$1")
endsnippet

snippet r "require" "around_const_let_var(snip)" we
${2:`!p snip.rv = importname(t[1])`} = require("$1")
endsnippet


priority 3

snippet me "module.exports" b
module.exports
endsnippet


priority 2

snippet pe "process" w
process.env
endsnippet
