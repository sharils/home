# Settings
# --------
# Most of these settings can be toggleable, either via the toggle-*
# actions or via the option menu (bound to `o` by default).

# View settings
#
# Supported column types and their options:
#
#   author
#    - display (enum) [no|full|abbreviated|email|email-user]
#                                       : Show author information?
#   commit-title
#    - display (bool)                   : Show the commit title?
#    - graph (enum) [no|v2|v1]          : Show the commit graph? (main view only)
#    - refs (bool)                      : Show branches, tags and remotes? (main view only)
#    - overflow (boolint)               : Highlight overflows? Defaults to 50 when enabled.
#
#   date
#    - display (enum) [no|default|relative|relative-compact|custom]
#                                       : Show dates?
#    - local (bool)                     : Show local dates?
#    - format (string)                  : Custom strftime(3) format
#
#   file-name
#    - display (enum) [no|always|auto]  : Show file names?
#
#   file-size
#    - display (enum) [no|default|units]    : Show file sizes?
#
#   id
#    - display (bool)                   : Show commit/tree ID?
#
#   line-number
#    - display (bool)                   : Show line numbers?
#    - interval (int)                   : Interval between line numbers; defaults to 5
#
#   mode
#    - display (bool)                   : Show file modes?
#
#   status
#    - display (enum) [no|short|long]   : Show status label?
#
#   text
#    - display (bool)                   : Show text?
#    - commit-title-overflow (boolint)  : Highlight overflow in log and diff view?
#
# All columns also support a width option to configure the max width of
# the column. Use zero (the default value) to auto-size the column based
# on the content.

set diff-highlight              = true
set diff-options                = --show-signature
set ignore-case                 = smart-case
set log-options                 = --show-signature
set main-view                   = line-number:no,interval=1 id:yes date:relative-compact author:no commit-title:yes,graph,refs,overflow=no
set mouse                       = yes
set mouse-scroll                = 1
set mouse-wheel-cursor          = yes
set status-show-untracked-files = yes

# User-defined commands
# ---------------------
# These commands allow to run shell commands directly from within Tig.
# Unless otherwise specified, commands are run in the foreground with
# their console output shown (as if '!' was specified). When multiple
# command options are specified their behavior are combined, e.g. "?<git
# commit" will prompt the user whether to execute the command and will
# exit Tig after completion.
#
#   !   Run the command in the foreground with output shown.
#   @   Run the command in the background with no output.
#   ?   Prompt the user before executing the command.
#   <   Exit Tig after executing the command.
#
# User-defined commands can optionally refer to Tig's internal state
# using the following variable names, which are substituted before
# commands are run:
#
#   %(head)         The current ref ID. Defaults to HEAD
#   %(commit)       The current commit ID.
#   %(blob)         The current blob ID.
#   %(branch)       The current branch name.
#   %(remote)       The current remote name.
#   %(tag)          The current tag name.
#   %(stash)        The current stash name.
#   %(directory)    The current directory path in the tree view;
#                   empty for the root directory.
#   %(file)         The currently selected file.
#   %(ref)          The reference given to blame or HEAD if undefined.
#   %(revargs)      The revision arguments passed on the command line.
#   %(fileargs)     The file arguments passed on the command line.
#   %(cmdlineargs)  All other options passed on the command line.
#   %(diffargs)     The diff options from `diff-options` or `TIG_DIFF_OPTS`
#   %(prompt)       Prompt for the argument value.

bind generic    <C-F>   move-page-down
bind generic    <C-B>   move-page-up
bind generic    g       none
bind generic    gg      move-first-line
bind main       G       move-last-line
bind generic    G       move-last-line
bind diff       ]       none
bind diff       [       none
bind diff       ]c      :/^@@
bind diff       [c      :?^@@
bind pager      ]c      :/^@@
bind pager      [c      :?^@@
bind stage      ]       none
bind stage      [       none
bind stage      ]c      :/^@@
bind stage      [c      :?^@@

# Follow fugitive-:Gstatus
bind status     !           none
bind status     u           none
bind status     -           status-update
bind status     c           none
bind status     ca          !git commit --amend
bind status     cc          !git commit
bind status     ce          !git commit --amend --no-edit
bind status     cw          !git commit --amend --only
bind status     cva         !git commit --verbose --amend
bind status     cvc         !git commit --verbose
bind status     D           enter
bind status     O           edit
bind status     P           !git add --patch %(file)
bind status     U           status-revert
bind stage      !           none
bind stage      u           none
bind stage      -           status-update
bind stage      O           edit
bind stage      P           !git reset --patch %(file)
bind stage      U           status-revert

bind generic    gba         view-refs
bind refs       gbd         !git branch --delete %(branch)
bind refs       gbD         !git branch --delete --force %(branch)
bind refs       gbm         !git branch --move %(branch) %(prompt)
bind main       gco<ENTER>  !git checkout %(commit)
bind status     gco<ENTER>  !git checkout %(commit)
bind main       gco-        !git checkout -
bind status     gco-        !git checkout -
bind main       gcop        !git checkout -p
bind status     gcop        !git checkout -p
bind main       gco.        !git checkout .
bind status     gco.        !git checkout .
bind main       gcp         !git cherry-pick %(commit)
bind status     gcp         !git cherry-pick %(commit)
bind main       gcf<ENTER>  !git commit --fixup %(commit)
bind status     gcf<ENTER>  !git commit --fixup %(commit)
bind main       gcfh        !git commit --fixup HEAD
bind status     gcfh        !git commit --fixup HEAD
bind main       gci         !git commit --interactive
bind status     gci         !git commit --interactive
bind main       gcrm        !git commit --reuse-message %(commit)
bind status     gcrm        !git commit --reuse-message %(commit)
bind main       gc<ENTER>   !git commit -v
bind status     gc<ENTER>   !git commit -v
bind main       gca<ENTER>  !git commit -v -a
bind status     gca<ENTER>  !git commit -v -a
bind main       gcam        !git commit -v -am %(prompt)
bind status     gcam        !git commit -v -am %(prompt)
bind main       gcm         !git commit -v -m %(prompt)
bind status     gcm         !git commit -v -m %(prompt)
bind status     gcm         !git commit -v -m %(prompt)
bind main       gd          !git diff %(commit) HEAD
bind status     gd          !git diff %(commit) HEAD
bind main       gf<ENTER>   !git fetch --all --prune
bind status     gf<ENTER>   !git fetch --all --prune
bind main       gft<ENTER>  !git fetch --all --prune --tags
bind status     gft<ENTER>  !git fetch --all --prune --tags
bind main       gftv        !git fetch --all --prune --tags --verbose
bind status     gftv        !git fetch --all --prune --tags --verbose
bind main       gfv         !git fetch --all --prune --verbose
bind status     gfv         !git fetch --all --prune --verbose
bind generic    ggr         view-blob
bind main       gl<ENTER>   !git pull
bind status     gl<ENTER>   !git pull
bind generic    gll         view-main
bind main       gpp         !git pull && git push
bind status     gpp         !git pull && git push
bind main       gpr         !git pull --rebase
bind status     gpr         !git pull --rebase
bind main       glum        !git pull upstream master
bind status     glum        !git pull upstream master
bind main       gp<ENTER>   !git push
bind status     gp<ENTER>   !git push
bind main       gph         !git push %(remote) %(commit):refs/heads/%(prompt)
bind status     gph         !git push %(remote) %(commit):refs/heads/%(prompt)
bind main       gpfh        !git push --force %(remote) %(commit):refs/heads/%(prompt)
bind status     gpfh        !git push --force %(remote) %(commit):refs/heads/%(prompt)
bind main       gpu<ENTER>  !git push --set-upstream
bind status     gpu<ENTER>  !git push --set-upstream
bind main       gpuo<ENTER> !git push --set-upstream origin
bind status     gpuo<ENTER> !git push --set-upstream origin
bind main       gpuof       !git push --set-upstream origin --force
bind status     gpuof       !git push --set-upstream origin --force
bind main       gpo<ENTER>  !git push origin
bind status     gpo<ENTER>  !git push origin
bind main       gpof        !git push origin -f
bind status     gpof        !git push origin -f
bind main       gpom        !git push origin master
bind status     gpom        !git push origin master
bind main       gpohm       !git push origin push origin HEAD:master
bind status     gpohm       !git push origin push origin HEAD:master
bind main       grba        !git rebase --abort
bind status     grba        !git rebase --abort
bind main       grbk        !git rebase --autosquash --interactive %(commit)
bind status     grbk        !git rebase --autosquash --interactive %(commit)
bind main       grbs        !git rebase --autosquash --interactive %(commit)
bind status     grbs        !git rebase --autosquash --interactive %(commit)
bind main       grbc        !git rebase --continue
bind status     grbc        !git rebase --continue
bind main       grbi        !git rebase --interactive %(commit)
bind status     grbi        !git rebase --interactive %(commit)
bind main       grbo        !git rebase --onto %(prompt) %(commit)
bind status     grbo        !git rebase --onto %(prompt) %(commit)
bind main       grbm        !git rebase origin/master
bind status     grbm        !git rebase origin/master
bind main       grsh        !git reset --hard %(commit)
bind status     grsh        !git reset --hard %(commit)
bind main       grsm        !git reset --merge
bind status     grsm        !git reset --merge
bind main       gus         !git reset HEAD
bind status     gus         !git reset HEAD
bind main       grs^        !git reset HEAD^
bind status     grs^        !git reset HEAD^
bind main       grvt        !git revert %(commit)
bind status     grvt        !git revert %(commit)
bind generic    gs          view-status
bind generic    gstl        view-stash
bind main       gstd        !git stash --drop
bind status     gstd        !git stash --drop
bind main       gstk        !git stash --keep-index
bind status     gstk        !git stash --keep-index
bind main       gstP        !git stash pop
bind status     gstP        !git stash pop
bind main       gstp        !git stash push
bind status     gstp        !git stash push
bind generic    gt<ENTER>   view-refs
bind refs       gta         !git tag -a
bind refs       gtd         !git tag -d
bind refs       gtl         !git tag -l


# Colors
# ------

# The colors in the UI can be customized. In addition to the colors used
# for the UI you can also define new colors to use in the pager, blob,
# diff, and stage views by placing the text to match for in quotes.
#
# Prefix the name of a view to set a color only for that view, e.g.
#
#   color grep.file blue default
#
# As an example, this setting will to color Signed-off-by lines with a
# yellow foreground color and use the default background color.
#
#   color "    Signed-off-by"   yellow  default
#
# Note the four leading spaces in the string to match. This is because
# Git automatically indents commit messages by four spaces.

color cursor black green bold
